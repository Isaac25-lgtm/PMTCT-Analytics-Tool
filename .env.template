# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# Application
APP_ENV=development
APP_VERSION=1.0.0
APP_NAME=PMTCT Triple Elimination Tool
APP_HOST=0.0.0.0
APP_PORT=8000
PORT=8000
APP_DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# DHIS2
# Use the DHIS2 base URL without a trailing /api path.
DHIS2_BASE_URL=https://hmis.health.go.ug
DHIS2_API_VERSION=2.39

# Session
SESSION_TIMEOUT_MINUTES=120

# LLM / AI (optional)
# Gemini example:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-3-flash-preview
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_AZURE_ENDPOINT=
LLM_ENABLED=true

# Security
RATE_LIMIT_ENABLED=false
CSRF_ENABLED=false
AUDIT_ENABLED=true

# Cache
CACHE_ENABLED=true
CACHE_MAX_SIZE=5000

# Connection pool
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE=20
HTTP_CONNECT_TIMEOUT=10
HTTP_READ_TIMEOUT=60
HTTP_WRITE_TIMEOUT=30
HTTP_POOL_TIMEOUT=30
